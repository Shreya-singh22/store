# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/evoc_checkout"

# =============================================================================
# PAYMENT GATEWAY (PayU)
# =============================================================================
PAYU_KEY="your-payu-key"
PAYU_SALT="your-payu-salt"
PAYU_CALLBACK_URL="http://localhost:3000/api/payu/callback"

# =============================================================================
# OTP SERVICE (2Factor.in)
# =============================================================================
TWO_FACTOR_API_KEY="your-2factor-api-key"

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV="development"

# =============================================================================
# NOTES FOR DEPLOYMENT
# =============================================================================
# 1. Copy this file to .env
# 2. Fill in the actual values (never commit .env to git)
# 3. For production, set these as environment variables in your hosting platform
#
# Required for production:
# - DATABASE_URL (PostgreSQL with ?channel_binding=disable for Neon)
# - PAYU_KEY & PAYU_SALT (Payment gateway credentials)
# - TWO_FACTOR_API_KEY (OTP service API key)
#
# Store ID comes from the API response, not from env variables.
# Subdomain is derived from hostname (moonstruck.evoclabs.com -> moonstruck).