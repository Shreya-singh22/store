# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/evoc_checkout"

# =============================================================================
# STORE CONFIGURATION
# =============================================================================
# Subdomain to use when running locally (no subdomain in URL)
# This determines which store's data is fetched from the API
NEXT_PUBLIC_SUBDOMAIN="moonstruck"

# Store ID for external API calls
NEXT_PUBLIC_STORE_ID="your-store-id-here"
STORE_ID="your-store-id-here"

# =============================================================================
# PAYMENT GATEWAY (PayU)
# =============================================================================
# PayU merchant credentials
NEXT_PUBLIC_PAYU_KEY="your-payu-key"
PAYU_KEY="your-payu-key"

PAYU_SALT="your-payu-salt"
PAYU_CALLBACK_URL="http://localhost:3000/api/payu/callback"

# =============================================================================
# OTP SERVICE (2Factor.in)
# =============================================================================
TWO_FACTOR_API_KEY="your-2factor-api-key"
NEXT_PUBLIC_TWO_FACTOR_API_KEY="your-2factor-api-key"

# =============================================================================
# APPLICATION
# =============================================================================
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3001"

# Cash on Delivery settings
MAX_COD_AMOUNT=15000

# =============================================================================
# NOTES FOR DEPLOYMENT
# =============================================================================
# 1. Copy this file to .env
# 2. Fill in the actual values (never commit .env to git)
# 3. For production, set these as environment variables in your hosting platform
#
# Required for production deployment:
# - DATABASE_URL (PostgreSQL database URL)
# - STORE_ID (Your store identifier)
# - TWO_FACTOR_API_KEY (OTP service API key)
# - PAYU_KEY & PAYU_SALT (Payment gateway credentials)
#
# Optional for production:
# - NEXT_PUBLIC_SUBDOMAIN (only needed for local development without subdomain)