generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  phone        String    @unique
  email        String?
  firstName    String?
  lastName     String?
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  otpRecords   OtpVerification[]
}

model Address {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String       @default("HOME")
  flatHouse   String
  areaStreet  String
  city        String
  state       String
  pincode     String
  phone       String?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, flatHouse, areaStreet, city, state, pincode])
  @@index([userId])
}

model Order {
  id                String           @id @default(cuid())
  storeId           String
  orderNumber       String           @unique
  customerEmail     String
  customerName      String
  shippingAddress   Json
  billingAddress    Json
  subtotal          Float
  tax               Float           @default(0)
  shipping          Float           @default(0)
  total             Float
  status            String          @default("PENDING")
  paymentMethod     String?
  paymentStatus     String          @default("PENDING")
  fulfillmentStatus String          @default("UNFULFILLED")
  couponCode        String?
  discountAmount    Float?
  freeShipping      Boolean         @default(false)
  source            String          @default("MANUAL")
  riskLevel         String          @default("Low")
  payuTxnId         String?          @unique
  payuStatus        String?
  payuResponse      Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  userId            String
  user              User             @relation(fields: [userId], references: [id])
  items             OrderItem[]

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  name        String
  quantity    Int
  price       Float
  variantInfo Json?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  code      String?
  sessionId String?
  expiresAt DateTime
  verified  Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([phone])
  @@index([userId])
}

model CheckoutSession {
  id        String   @id @default(cuid())
  phone     String
  deviceId  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, deviceId])
  @@index([expiresAt])
}